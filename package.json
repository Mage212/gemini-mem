{
  "name": "antigravity-memory",
  "version": "0.3.0",
  "description": "Persistent memory layer for Antigravity IDE via MCP — never lose context across sessions",
  "author": "Keyut Shah",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mage212/gemini-mem.git"
  },
  "homepage": "https://github.com/Mage212/gemini-mem#readme",
  "bugs": {
    "url": "https://github.com/Mage212/gemini-mem/issues"
  },
  "bin": {
    "antigravity-mem": "./dist/cli/index.js",
    "antigravity-memory": "./dist/cli/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "templates/**/*",
    "docs/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node src/cli/index.ts",
    "init": "ts-node src/cli/index.ts init",
    "api": "ts-node src/api/server.ts",
    "mcp": "ts-node src/mcp/server.ts",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "antigravity",
    "gemini",
    "memory",
    "context",
    "mcp",
    "ai",
    "coding",
    "ide"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.6.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
